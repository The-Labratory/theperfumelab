# ─────────────────────────────────────────────────────────────────────────────
# Scentra World Builder — Environment Variables Template
# Copy this file to .env and fill in real values.
# NEVER commit .env to source control.
# ─────────────────────────────────────────────────────────────────────────────

# ── Supabase ──────────────────────────────────────────────────────────────────
# Found in: Supabase dashboard → Project Settings → API
VITE_SUPABASE_URL=https://xxslrzwtovhteueipsix.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=<your-anon-key>  # anon/public key — Supabase Dashboard → Project Settings → API
VITE_SUPABASE_PROJECT_ID=xxslrzwtovhteueipsix

# ── Shopify Storefront API ────────────────────────────────────────────────────
# Found in: Shopify Admin → Apps → Develop apps → Storefront API access token
# Scope required: unauthenticated_read_product_listings, unauthenticated_write_checkouts
VITE_SHOPIFY_STORE_DOMAIN=your-store.myshopify.com
VITE_SHOPIFY_STOREFRONT_TOKEN=your_storefront_access_token

# ── Edge Function Secrets (set via Supabase dashboard, NOT in .env) ───────────
# supabase secrets set LOVABLE_API_KEY=your_key
# These are Deno.env.get() values inside supabase/functions/ — never in .env
